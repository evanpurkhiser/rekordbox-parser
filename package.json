{
  "name": "rekordbox-parser",
  "version": "0.1.2",
  "keywords": [
    "CDJ",
    "DJ",
    "crate-digger",
    "dysentery",
    "pioneer",
    "rekordbox"
  ],
  "license": "LGPL-3.0-or-later",
  "author": "Evan Purkhiser <evanpurkhiser@gmail.com>",
  "files": [
    "lib/*",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "sideEffects": false,
  "main": "lib/index.js",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.0.0"
    }
  },
  "scripts": {
    "build": "tsc && cp src/RekordboxAnlz.js src/RekordboxPdb.js lib/",
    "build-parsers": "ts-node-esm --project tsconfig.update.json src/update.mts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src/*",
    "test": "jest"
  },
  "dependencies": {
    "kaitai-struct": "^0.10.0"
  },
  "devDependencies": {
    "@evanpurkhiser/oxc-config": "^0.8.0",
    "@jest/globals": "^29.2.2",
    "@octokit/types": "^8.0.0",
    "@types/node": "^18.11.5",
    "jest": "^29.2.2",
    "kaitai-struct-compiler": "^0.10.0",
    "node-fetch": "^3.2.10",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.4",
    "yaml": "^2.1.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
